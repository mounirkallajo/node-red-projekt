    async function handleRouteRequest() {
      const startPosition = await resolveRouteStartPosition();
      if (!startPosition) {
        throw new Error('Startposition konnte nicht ermittelt werden. Bitte Standort wählen oder OwnTracks-Position abwarten.');
      }
      const routeQueryElement = byId('routeQuery');
