function appendFinalRoutePointToHistory(history, position, recentSpeedsMps) {
    history = Array.isArray(history) ? history : [];
    const lastPoint = history.length > 0 ? history[history.length - 1] : null;
    if (lastPoint) {
        if (position.trackId && lastPoint.trackId === position.trackId &&
            position.sequenceNumber != null && lastPoint.sequenceNumber === position.sequenceNumber) {
            return { history: history, added: false, recentSpeedsMps: recentSpeedsMps || [] };
        }
        if (lastPoint.timestamp === position.timestamp && lastPoint.lat === position.lat && lastPoint.lon === position.lon) {
            return { history: history, added: false, recentSpeedsMps: recentSpeedsMps || [] };
        }
        const timeGapSeconds = Math.max(0.001, ((Number(position.timestamp) || Date.now()) - (Number(lastPoint.timestamp) || 0)) / 1000);
        const estimatedSpeedMps = distanceMeters(lastPoint, position) / timeGapSeconds;
        recentSpeedsMps = Number.isFinite(estimatedSpeedMps)
            ? pushRecentSpeedSample(recentSpeedsMps, estimatedSpeedMps)
            : (recentSpeedsMps || []);
    }
    history.push(position);
    if (history.length > MAX_HISTORY) history = history.slice(-MAX_HISTORY);
    return { history: history, added: true, recentSpeedsMps: recentSpeedsMps || [] };
