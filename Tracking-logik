function normalizeDeviceColor(value) {
    const color = typeof value === "string" ? value.trim() : "";
    return /^#[0-9a-fA-F]{6}$/.test(color) ? color : "";
}

function ensureDeviceColor(deviceKey, devices, colorByKey) {
    if (!deviceKey) return DEVICE_COLOR_PALETTE[0];
    const existing = normalizeDeviceColor(colorByKey[deviceKey]) ||
        normalizeDeviceColor(devices[deviceKey] && (devices[deviceKey].deviceColor || devices[deviceKey].color));
    if (existing) {
        colorByKey[deviceKey] = existing;
        return existing;
    }
    const used = {};
    Object.keys(devices || {}).forEach(function (key) {
        if (key === deviceKey) return;
        const color = normalizeDeviceColor(colorByKey[key]) ||
            normalizeDeviceColor(devices[key] && (devices[key].deviceColor || devices[key].color));
        if (color) used[color.toLowerCase()] = true;
    });
    const available = DEVICE_COLOR_PALETTE.filter(function (color) {
        return !used[color.toLowerCase()];
    });
    let hash = 0;
    for (let i = 0; i < deviceKey.length; i += 1) {
        hash = ((hash << 5) - hash) + deviceKey.charCodeAt(i);
        hash |= 0;
    }
    const chosen = (available.length ? available : DEVICE_COLOR_PALETTE)[(hash >>> 0) % (available.length || DEVICE_COLOR_PALETTE.length)];
    colorByKey[deviceKey] = chosen;
    return chosen;
}

